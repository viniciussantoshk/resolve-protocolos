# ============================================================
#  Resolve Assist — Arquivo de Configuração de Ambiente
#  Copie este arquivo para ".env" e preencha os valores.
# ============================================================

# --- Servidor ---
PORT=3000
HOST=0.0.0.0

# --- Ambiente (development | production) ---
NODE_ENV=development

# --- Segurança ---
# IMPORTANTE: Troque por uma string longa e aleatória em produção!
# Gere uma com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=TROQUE_ESTA_CHAVE_POR_UMA_STRING_ALEATORIA_LONGA

# --- Banco de Dados ---
DB_PATH=./data/resolve-assist.db

# --- Origens permitidas (CORS) ---
# Em produção, coloque o domínio real do sistema
ALLOWED_ORIGINS=http://localhost:3000

# --- Logs ---
# Níveis: error | warn | info | debug
LOG_LEVEL=info
